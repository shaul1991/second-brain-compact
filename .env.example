PRIVATE_REPO_PATH=/data
INGESTION_CAPTURE_PATH=/data/capture/default
INGESTION_LEDGER_PATH=/runtime/ingestion/seen-keys
MCP_AUDIT_LOG=/runtime/mcp/audit.log.jsonl
MCP_DEVICE=local
DATA_GIT_BRANCH=main

# --- Optional semantic search (supermemory). OFF by default. ---
# Set to true and start the semantic profile to enable meaning-based recall.
# When false (default), recall uses local keyword search only.
SEMANTIC_SEARCH_ENABLED=false
# Must be a LOCAL/private endpoint — the client refuses public hosts (no egress).
SUPERMEMORY_BASE_URL=http://supermemory:6767
SUPERMEMORY_CONTAINER_TAG=sb-local
# Leave empty for a keyless local self-host; set if your instance requires it.
SUPERMEMORY_API_KEY=
SEMANTIC_TIMEOUT_SECONDS=5

